# Copy to .env and fill in values.

BOT_TOKEN=
OPENROUTER_API_KEY=

# PostgreSQL (SQLAlchemy 2 async + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_ecosystem

# Legacy discrete vars (optional fallback)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_ecosystem
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# HTTP API (health checks)
API_HOST=0.0.0.0
API_PORT=8080
