# Copy to .env and fill in values.

BOT_TOKEN=
OPENROUTER_API_KEY=

# PostgreSQL (SQLAlchemy 2 async + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_ecosystem

# Legacy discrete vars (optional fallback)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_ecosystem
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# HTTP API (health checks)
API_HOST=0.0.0.0
API_PORT=8080

# Redis (FSM storage)
REDIS_URL=redis://localhost:6379/0
REDIS_REQUIRED=false

# Platform Telegram user ids
OWNER_ID=1208044579
DEFAULT_AUTO_MANAGER_ID=393792086
DEFAULT_DEALER_MANAGER_ID=8312013093
# Optional display names for MANAGERS registry
# DEFAULT_AUTO_MANAGER_NAME=Борис
# DEFAULT_DEALER_MANAGER_NAME=Tony

# Auto Marketing Engine — Telegram channel for publications
MARKETING_TELEGRAM_CHANNEL_ID=

# Automotive Treasury / Dealer Quote Authority — Foma Rates channel (authoritative)
# Automotive Treasury / BidEx @bidex_Odesa — authoritative dealer FX rates
BIDEX_TELEGRAM_CHANNEL_USERNAME=bidex_Odesa
BIDEX_TELEGRAM_CHANNEL_ID=
# Legacy Foma Rates channel (optional fallback)
